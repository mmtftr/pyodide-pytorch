From 26b47bee18f72ad9aee875e0b091f28d7fdc19f5 Mon Sep 17 00:00:00 2001
From: pytorch-pyodide maintainers <noreply@github.com>
Date: Sun, 19 Jul 2026 11:46:26 +0300
Subject: [PATCH 3/4] Use a host protoc when cross-compiling
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Require a native protoc from PyTorch’s pinned protobuf submodule so the WebAssembly build never executes a target binary.
---
 CMakeLists.txt | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 13776f1e..33f830e9 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -708,6 +708,16 @@ endif()
 
 if(EMSCRIPTEN)
   add_compile_definitions(PYTORCH_WASM_NO_THREADS=1)
+  if(NOT DEFINED ENV{PYTORCH_HOST_PROTOC} OR
+     NOT EXISTS "$ENV{PYTORCH_HOST_PROTOC}")
+    message(FATAL_ERROR
+      "PYTORCH_HOST_PROTOC must name a native protoc built from the pinned "
+      "third_party/protobuf submodule")
+  endif()
+  set(PROTOBUF_PROTOC_EXECUTABLE "$ENV{PYTORCH_HOST_PROTOC}"
+      CACHE FILEPATH "Host protoc for WebAssembly cross-compilation" FORCE)
+  set(CAFFE2_CUSTOM_PROTOC_EXECUTABLE "$ENV{PYTORCH_HOST_PROTOC}"
+      CACHE FILEPATH "Host protoc for WebAssembly cross-compilation" FORCE)
 endif()
 
 # Set INTERN_BUILD_MOBILE for all mobile builds. Components that are not
