-extern "C" void sgetrf_(int *m, int *n, float *a, int *lda, int *ipiv, int *info);
+extern "C" FORTRAN_SUBROUTINE_RETURN_TYPE zgetrf_(int *m, int *n, std::complex<double> *a, int *lda, int *ipiv, int *info);
+extern "C" FORTRAN_SUBROUTINE_RETURN_TYPE cgetrf_(int *m, int *n, std::complex<float> *a, int *lda, int *ipiv, int *info);
