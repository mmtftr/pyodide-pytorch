From 86b477e61c5fde97d13b9f7b3bf40b6e79d53555 Mon Sep 17 00:00:00 2001
From: pytorch-pyodide maintainers <noreply@github.com>
Date: Fri, 17 Jul 2026 00:00:00 +0300
Subject: [PATCH 1/6] Add Pyodide runtime guards

Avoid native dynamic-library and shared-memory setup in Pyodide. Emscripten's
size_t also needs the explicit symbolic integer overload, while its libc owns
the __assert_fail declaration.
---
 c10/core/SymInt.cpp | 2 +-
 c10/core/SymInt.h   | 2 +-
 c10/macros/Macros.h | 2 ++
 torch/__init__.py   | 5 +++++
 4 files changed, 9 insertions(+), 2 deletions(-)

diff --git a/c10/core/SymInt.cpp b/c10/core/SymInt.cpp
index dd5029c..29a6ad5 100644
--- a/c10/core/SymInt.cpp
+++ b/c10/core/SymInt.cpp
@@ -235,7 +235,7 @@ DEFINE_SYMINT_OP(uint32_t, SymInt)
 DEFINE_SYMINT_OP(double, SymFloat)
 DEFINE_SYMINT_OP(float, SymFloat) // just for completeness
 
-#if defined(__APPLE__)
+#if defined(__APPLE__) || defined(__EMSCRIPTEN__)
 DEFINE_SYMINT_OP_INTONLY(size_t, SymInt) // needed for osx
 DEFINE_SYMINT_OP(size_t, SymInt) // needed for osx
 #endif
diff --git a/c10/core/SymInt.h b/c10/core/SymInt.h
index 5b0ccf1..468e1b2 100644
--- a/c10/core/SymInt.h
+++ b/c10/core/SymInt.h
@@ -336,7 +336,7 @@ DECLARE_SYMINT_OP(float, SymFloat) // just for completeness
 
 // On OSX size_t is different than uint64_t so we have to
 // define it separately
-#if defined(__APPLE__)
+#if defined(__APPLE__) || defined(__EMSCRIPTEN__)
 DECLARE_SYMINT_OP_INTONLY(size_t, SymInt)
 DECLARE_SYMINT_OP(size_t, SymInt)
 #endif
diff --git a/c10/macros/Macros.h b/c10/macros/Macros.h
index 92b941b..01458a5 100644
--- a/c10/macros/Macros.h
+++ b/c10/macros/Macros.h
@@ -382,6 +382,7 @@ extern SYCL_EXTERNAL void __assert_fail(
 __host__ __device__
 #endif
 
+#if !defined(__EMSCRIPTEN__)
     // This forward declaration matching the declaration of __assert_fail
     // exactly how it is in glibc in case parts of the program are compiled with
     // different NDEBUG settings. Otherwise we might get 'ambiguous declaration'
@@ -392,6 +393,7 @@ __host__ __device__
         const char* file,
         unsigned int line,
         const char* function) noexcept __attribute__((__noreturn__));
+#endif
 
 #if (defined(__HIP_ARCH__) || defined(__HIP__)) && \
     !defined(TORCH_DISABLE_GPU_ASSERTS)
diff --git a/torch/__init__.py b/torch/__init__.py
index 881f0e3..772c230 100644
--- a/torch/__init__.py
+++ b/torch/__init__.py
@@ -163,6 +163,9 @@ def _preload_cuda_deps(lib_folder, lib_name):
 
 # See Note [Global dependencies]
 def _load_global_deps() -> None:
+    if sys.platform == "emscripten":
+        return
+
     if _running_with_deploy() or platform.system() == 'Windows':
         return
 
@@ -1313,6 +1316,8 @@ from ._tensor_str import set_printoptions
 ################################################################################
 
 def manager_path():
+    if sys.platform == "emscripten":
+        return b""
     if _running_with_deploy() or platform.system() == 'Windows':
         return b""
     path = get_file_path('torch', 'bin', 'torch_shm_manager')
-- 
