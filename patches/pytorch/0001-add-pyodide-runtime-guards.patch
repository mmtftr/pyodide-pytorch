From 51008bc99788fc12c55d665d049762e10b6ecdbe Mon Sep 17 00:00:00 2001
From: pytorch-pyodide maintainers <noreply@github.com>
Date: Sun, 19 Jul 2026 11:45:03 +0300
Subject: [PATCH 1/6] Add Pyodide runtime guards

Avoid native dynamic-library and shared-memory setup in Pyodide, and provide Emscripten size_t symbolic integer overloads.
---
 c10/core/SymInt.cpp | 2 +-
 c10/core/SymInt.h   | 2 +-
 torch/__init__.py   | 5 +++++
 3 files changed, 7 insertions(+), 2 deletions(-)

diff --git a/c10/core/SymInt.cpp b/c10/core/SymInt.cpp
index 1078ae03..92a3a12c 100644
--- a/c10/core/SymInt.cpp
+++ b/c10/core/SymInt.cpp
@@ -272,7 +272,7 @@ DEFINE_SYMINT_OP(uint32_t, SymInt)
 DEFINE_SYMINT_OP(double, SymFloat)
 DEFINE_SYMINT_OP(float, SymFloat) // just for completeness
 
-#if defined(__APPLE__)
+#if defined(__APPLE__) || defined(__EMSCRIPTEN__)
 DEFINE_SYMINT_OP_INTONLY(size_t, SymInt) // needed for osx
 DEFINE_SYMINT_OP(size_t, SymInt) // needed for osx
 #endif
diff --git a/c10/core/SymInt.h b/c10/core/SymInt.h
index ad004a5b..0ac43a67 100644
--- a/c10/core/SymInt.h
+++ b/c10/core/SymInt.h
@@ -493,7 +493,7 @@ DECLARE_SYMINT_OP(float, SymFloat) // just for completeness
 
 // On OSX size_t is different than uint64_t so we have to
 // define it separately
-#if defined(__APPLE__)
+#if defined(__APPLE__) || defined(__EMSCRIPTEN__)
 DECLARE_SYMINT_OP_INTONLY(size_t, SymInt)
 DECLARE_SYMINT_OP(size_t, SymInt)
 #endif
diff --git a/torch/__init__.py b/torch/__init__.py
index 629122af..10d44e6e 100644
--- a/torch/__init__.py
+++ b/torch/__init__.py
@@ -367,6 +367,9 @@ def _preload_cuda_deps(err: OSError | None = None) -> None:
 
 # See Note [Global dependencies]
 def _load_global_deps() -> None:
+    if sys.platform == "emscripten":
+        return
+
     if platform.system() == "Windows":
         return
 
@@ -2177,6 +2180,8 @@ from torch.serialization import load, save
 
 # Shared memory manager needs to know the exact location of manager executable
 def _manager_path():
+    if sys.platform == "emscripten":
+        return b""
     if platform.system() == "Windows":
         return b""
     path = get_file_path("torch", "bin", "torch_shm_manager")
