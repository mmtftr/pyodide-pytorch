+    const char*, const char*, int, size_t) {
+  TORCH_CHECK(
+      false,
+      "file-system shared storage is unavailable in this WebAssembly build");
+  return {};
+}
+
+THManagedMapAllocator* THManagedMapAllocator::fromDataPtr(
+    const at::DataPtr&) {
+  return nullptr;
+}
