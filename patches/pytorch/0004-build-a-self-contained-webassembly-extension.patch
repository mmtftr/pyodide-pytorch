From c3562880713f98c8df44b94b42a0248d5f1101f5 Mon Sep 17 00:00:00 2001
From: pytorch-pyodide maintainers <noreply@github.com>
Date: Sun, 19 Jul 2026 11:51:39 +0300
Subject: [PATCH 4/5] Build a self-contained WebAssembly extension

Build torch_python as a static archive for Emscripten and whole-archive it into torch._C through the CMake target graph. Omit unsupported shared-memory and lazy TorchScript backend paths.
---
 torch/CMakeLists.txt            | 24 ++++++++++++++---
 torch/csrc/Module.cpp           |  4 +++
 torch/csrc/StorageSharing.cpp   | 15 +++++++++++
 torch/csrc/lazy/python/init.cpp | 46 +++++++++++++++++++++++++--------
 4 files changed, 75 insertions(+), 14 deletions(-)

diff --git a/torch/CMakeLists.txt b/torch/CMakeLists.txt
index 23aa88dd..4587c64b 100644
--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -27,7 +27,9 @@ else()
 endif()
 
 set(LIBSHM_SRCDIR ${TORCH_SRC_DIR}/lib/${LIBSHM_SUBDIR})
-add_subdirectory(${LIBSHM_SRCDIR})
+if(NOT EMSCRIPTEN)
+  add_subdirectory(${LIBSHM_SRCDIR})
+endif()
 
 # Generate files
 set(TOOLS_PATH "${TORCH_ROOT}/tools")
@@ -85,6 +87,9 @@ set(TORCH_PYTHON_LINK_LIBRARIES
     shm
     fmt::fmt-header-only
     ATEN_CPU_FILES_GEN_LIB)
+if(EMSCRIPTEN)
+  list(REMOVE_ITEM TORCH_PYTHON_LINK_LIBRARIES shm)
+endif()
 
 if(USE_ASAN AND TARGET Sanitizer::address)
   list(APPEND TORCH_PYTHON_LINK_LIBRARIES Sanitizer::address)
@@ -104,6 +109,10 @@ endif()
 
 set(TORCH_PYTHON_COMPILE_DEFINITIONS)
 
+if(EMSCRIPTEN AND NOT BUILD_LAZY_TS_BACKEND)
+  list(APPEND TORCH_PYTHON_COMPILE_DEFINITIONS PYTORCH_WASM_NO_LAZY_TS_BACKEND=1)
+endif()
+
 set(TORCH_PYTHON_COMPILE_OPTIONS)
 
 set(TORCH_PYTHON_LINK_FLAGS "")
@@ -295,7 +304,11 @@ if(USE_COREML_DELEGATE)
 endif()
 
 
-add_library(torch_python SHARED ${TORCH_PYTHON_SRCS})
+if(EMSCRIPTEN)
+  add_library(torch_python STATIC ${TORCH_PYTHON_SRCS})
+else()
+  add_library(torch_python SHARED ${TORCH_PYTHON_SRCS})
+endif()
 torch_compile_options(torch_python)  # see cmake/public/utils.cmake
 if(APPLE)
   target_compile_options(torch_python PRIVATE
@@ -447,7 +460,12 @@ install(TARGETS torch_python DESTINATION "${TORCH_INSTALL_LIB_DIR}")
 # same code path.
 if(BUILD_PYTHON AND NOT BUILD_LIBTORCH_WHL)
   Python_add_library(_C MODULE WITH_SOABI "${TORCH_SRC_DIR}/csrc/stub.c")
-  target_link_libraries(_C PRIVATE torch_python)
+  if(EMSCRIPTEN)
+    target_link_libraries(
+      _C PRIVATE $<LINK_LIBRARY:WHOLE_ARCHIVE,torch_python>)
+  else()
+    target_link_libraries(_C PRIVATE torch_python)
+  endif()
   set_target_properties(_C PROPERTIES
     LIBRARY_OUTPUT_DIRECTORY "${CMAKE_BINARY_DIR}/torch"
     # libtorch_python.so is installed to lib/ relative to _C, so use
diff --git a/torch/csrc/Module.cpp b/torch/csrc/Module.cpp
index 5bc69ddb..addfe45d 100644
--- a/torch/csrc/Module.cpp
+++ b/torch/csrc/Module.cpp
@@ -33,7 +33,9 @@
 #include <c10/util/Logging.h>
 #include <c10/util/irange.h>
 #include <c10/util/thread_name.h>
+#ifndef __EMSCRIPTEN__
 #include <libshm.h>
+#endif
 #include <pybind11/pybind11.h>
 #include <pybind11/stl.h>
 #include <torch/csrc/THConcat.h>
@@ -238,8 +240,10 @@ static PyObject* THPModule_initExtension(
   torch::utils::initializeQSchemes();
   torch::utils::initializeDtypes();
   torch::tensors::initialize_python_bindings();
+#ifndef __EMSCRIPTEN__
   std::string path = THPUtils_unpackString(shm_manager_path);
   libshm_init(path.c_str());
+#endif
 
   auto module = THPObjectPtr(PyImport_ImportModule("torch"));
   if (!module)
diff --git a/torch/csrc/StorageSharing.cpp b/torch/csrc/StorageSharing.cpp
index f8fab0ed..98f22703 100644
--- a/torch/csrc/StorageSharing.cpp
+++ b/torch/csrc/StorageSharing.cpp
@@ -32,6 +32,21 @@
 #include <atomic>
 #include <string>
 
+#ifdef __EMSCRIPTEN__
+at::DataPtr THManagedMapAllocator::makeDataPtr(
+    const char*, const char*, int, size_t) {
+  TORCH_CHECK(
+      false,
+      "file-system shared storage is unavailable in this WebAssembly build");
+  return {};
+}
+
+THManagedMapAllocator* THManagedMapAllocator::fromDataPtr(
+    const at::DataPtr&) {
+  return nullptr;
+}
+#endif
+
 static PyObject* THPStorage_sharedDecref(PyObject* self, PyObject* noargs) {
   HANDLE_TH_ERRORS
   THPStorage_assertNotNull(self);
