From 65ff9916699b31d968a17a06cf5bc97c849963c2 Mon Sep 17 00:00:00 2001
From: pytorch-pyodide maintainers <noreply@github.com>
Date: Thu, 17 Jul 2026 00:00:03 +0300
Subject: [PATCH 4/5] Link static libtorch into the extension

Pyodide loads one WebAssembly side module. PyTorch explicitly builds its Python
binding and POSIX shared-memory helper as shared libraries even when
BUILD_SHARED_LIBS is disabled, so the extension otherwise retains a dependency
on a pruned libtorch_python.so. Build the binding as an archive, omit the
fork/socket-based shared-memory helper on Emscripten, and whole-archive the two
registrar-bearing archives into torch._C.
---
 setup.py              | 36 ++++++++++++++++++++++++++++++++++++
 torch/CMakeLists.txt  |  9 +++++++++
 torch/csrc/Module.cpp |  4 ++++
 3 files changed, 49 insertions(+)

diff --git a/setup.py b/setup.py
index 55f333e..81831dd 100644
--- a/setup.py
+++ b/setup.py
@@ -939,8 +939,44 @@ def configure_extension_build():
     main_compile_args = []
     main_libraries = ["torch_python"]
     main_link_args = []
     main_sources = ["torch/csrc/stub.c"]
+
+    if (
+        sysconfig.get_platform().startswith("emscripten")
+        and not cmake_cache_vars["BUILD_SHARED_LIBS"]
+    ):
+        whole_archives = [
+            os.path.join(lib_path, "libtorch_python.a"),
+            os.path.join(lib_path, "libtorch_cpu.a"),
+        ]
+        support_archives = [
+            os.path.join(lib_path, name)
+            for name in (
+                "libc10.a",
+                "libfmt.a",
+                "libprotobuf.a",
+                "libcpuinfo.a",
+                "libclog.a",
+            )
+            if os.path.exists(os.path.join(lib_path, name))
+        ]
+        missing_archives = [
+            path for path in whole_archives if not os.path.exists(path)
+        ]
+        if missing_archives:
+            raise RuntimeError(
+                "Missing static libraries for the WebAssembly extension: "
+                + ", ".join(missing_archives)
+            )
+        main_libraries = []
+        main_link_args.extend(
+            ["-Wl,--whole-archive"]
+            + whole_archives
+            + ["-Wl,--no-whole-archive", "-Wl,--start-group"]
+            + support_archives
+            + ["-Wl,--end-group"]
+        )
 
     if cmake_cache_vars["USE_CUDA"]:
         library_dirs.append(os.path.dirname(cmake_cache_vars["CUDA_CUDA_LIB"]))
 
diff --git a/torch/CMakeLists.txt b/torch/CMakeLists.txt
index e5990f3..2589047 100644
--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -32,4 +32,6 @@ endif()
 
 set(LIBSHM_SRCDIR ${TORCH_SRC_DIR}/lib/${LIBSHM_SUBDIR})
+if(NOT EMSCRIPTEN)
 add_subdirectory(${LIBSHM_SRCDIR})
+endif()
 
@@ -83,10 +85,13 @@ set(TORCH_PYTHON_LINK_LIBRARIES
 set(TORCH_PYTHON_LINK_LIBRARIES
     python::python
     pybind::pybind11
     shm
     fmt::fmt-header-only
     ATEN_CPU_FILES_GEN_LIB)
+if(EMSCRIPTEN)
+  list(REMOVE_ITEM TORCH_PYTHON_LINK_LIBRARIES shm)
+endif()
 
 if(USE_ASAN AND TARGET Sanitizer::address)
   list(APPEND TORCH_PYTHON_LINK_LIBRARIES Sanitizer::address)
 endif()
@@ -300,5 +305,9 @@ if(CMAKE_COMPILER_IS_GNUCXX AND (CMAKE_CXX_COMPILER_VERSION VERSION_GREATER 9.0
+if(EMSCRIPTEN)
+  add_library(torch_python STATIC ${TORCH_PYTHON_SRCS})
+else()
 add_library(torch_python SHARED ${TORCH_PYTHON_SRCS})
+endif()
 # Avoid numpy for the DEPLOY build
 if(USE_NUMPY)
   target_link_libraries(torch_python PRIVATE numpy::numpy)
   target_compile_definitions(torch_python PRIVATE USE_NUMPY)
diff --git a/torch/csrc/Module.cpp b/torch/csrc/Module.cpp
index 8c321a1..a12c790 100644
--- a/torch/csrc/Module.cpp
+++ b/torch/csrc/Module.cpp
@@ -22,7 +22,9 @@
 #include <c10/util/Backtrace.h>
 #include <c10/util/Logging.h>
 #include <c10/util/irange.h>
+#ifndef __EMSCRIPTEN__
 #include <libshm.h>
+#endif
 #include <pybind11/pybind11.h>
 #include <pybind11/stl.h>
 #include <torch/csrc/THConcat.h>
@@ -152,7 +154,9 @@ static PyObject* THPModule_initExtension(
   torch::utils::initializeDtypes();
   torch::tensors::initialize_python_bindings();
+#ifndef __EMSCRIPTEN__
   std::string path = THPUtils_unpackString(shm_manager_path);
   libshm_init(path.c_str());
+#endif
 
   auto module = THPObjectPtr(PyImport_ImportModule("torch"));
   if (!module)
-- 
