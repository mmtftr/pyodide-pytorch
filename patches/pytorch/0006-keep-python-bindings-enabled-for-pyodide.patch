From 8731f18fc287b5d346d5b8814c376736666f1b8e Mon Sep 17 00:00:00 2001
From: pytorch-pyodide maintainers <noreply@github.com>
Date: Sun, 19 Jul 2026 22:18:14 +0300
Subject: [PATCH 6/6] Keep Python bindings enabled for Pyodide

Pass Pyodide's target Python headers to CMake explicitly. Newer PyTorch
otherwise accepts the host interpreter but rejects Development.Module while
cross-compiling, silently disables BUILD_PYTHON, and produces a wheel without
torch._C or generated version metadata.

Fail configuration instead of silently building LibTorch if the target Python
headers are ever rejected again.

FindPython also leaves the target SOABI empty while cross-compiling, so CMake
names the extension _C.so even when WITH_SOABI is requested. Package that exact
generic filename for Pyodide, whose extension loader supports the .so suffix.
---
 cmake/Dependencies.cmake     |  5 +++++
 setup.py                     | 16 ++++++++++++++--
 tools/setup_helpers/cmake.py | 12 ++++++++++++
 3 files changed, 31 insertions(+), 2 deletions(-)

diff --git a/cmake/Dependencies.cmake b/cmake/Dependencies.cmake
index 2baa187..7353e7f 100644
--- a/cmake/Dependencies.cmake
+++ b/cmake/Dependencies.cmake
@@ -877,6 +877,11 @@ if(BUILD_PYTHON)
     # Observers are required in the python build
     caffe2_update_option(USE_OBSERVERS ON)
   else()
+    if(EMSCRIPTEN)
+      message(FATAL_ERROR
+        "Python target headers were not found for the Emscripten build. "
+        "Set PYODIDE_PYTHON_INCLUDE_DIR to Pyodide's python_include_dir.")
+    endif()
     message(WARNING "Python dependencies not met. Not compiling with python. Suppress this warning with -DBUILD_PYTHON=OFF")
     caffe2_update_option(BUILD_PYTHON OFF)
   endif()
diff --git a/setup.py b/setup.py
index bcadb7a..14d9fa3 100644
--- a/setup.py
+++ b/setup.py
@@ -1169,13 +1169,25 @@ def main() -> None:
     ) = configure_extension_build()
     install_requires += extra_install_requires
 
+    torch_c_extension = f"_C{sysconfig.get_config_var('EXT_SUFFIX')}"
+    if os.getenv("PYODIDE_PYTHON_INCLUDE_DIR"):
+        # FindPython cannot infer the target SOABI while cross-compiling, so
+        # Python_add_library(... WITH_SOABI) emits the generic _C.so name.
+        # Pyodide's extension loader accepts that generic suffix.
+        torch_c_extension = "_C.so"
+        extension_path = TORCH_DIR / torch_c_extension
+        if RUN_BUILD_DEPS and not extension_path.is_file():
+            raise RuntimeError(
+                f"CMake did not install the Pyodide extension: {extension_path}"
+            )
+
     torch_package_data = [
         "py.typed",
         # torch._C is built by CMake (torch/CMakeLists.txt) and installed into
-        # torch/.  Match this interpreter's exact extension suffix, not a glob:
+        # torch/. Match its exact output name, not a glob:
         # build_all.sh reuses one build/ dir across Python versions, so a glob
         # would also pick up other ABIs' _C modules left behind in the tree.
-        f"_C{sysconfig.get_config_var('EXT_SUFFIX')}",
+        torch_c_extension,
         "bin/*",
         "bin/**/*",
         "test/*",
diff --git a/tools/setup_helpers/cmake.py b/tools/setup_helpers/cmake.py
index da48473..e655307 100644
--- a/tools/setup_helpers/cmake.py
+++ b/tools/setup_helpers/cmake.py
@@ -287,6 +287,18 @@ class CMake:
             "BUILD_TEST": build_test,
         }
 
+        # FindPython cannot infer target headers from the host interpreter
+        # while cross-compiling. Pyodide supplies the target include directory
+        # explicitly so CMake keeps BUILD_PYTHON enabled and creates torch._C.
+        if pyodide_python_include := my_env.get("PYODIDE_PYTHON_INCLUDE_DIR"):
+            python_header = os.path.join(pyodide_python_include, "Python.h")
+            if not os.path.isfile(python_header):
+                raise RuntimeError(
+                    "PYODIDE_PYTHON_INCLUDE_DIR does not contain Python.h: "
+                    f"{pyodide_python_include}"
+                )
+            build_options["Python_INCLUDE_DIR"] = pyodide_python_include
+
         use_numpy = not check_negative_env_flag("USE_NUMPY")
         build_options["USE_NUMPY"] = use_numpy
         if use_numpy:
-- 
